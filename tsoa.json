{
    "entryFile": "src/app.ts",
    "noImplicitAdditionalProperties": "throw-on-extras",
    "controllerPathGlobs": ["src/controllers/**/*.controller.ts"],
    "spec": {
        "outputDirectory": "docs",
        "specVersion": 3,
        "name": "Jukebox API",
        "title": "Jukebox API",
        "description": "Create a group with your friends, search songs on YouTube, vote for the next track and listen together.",
        "version": "1.0.0",
        "contact": {
            "name": "CapyBlaze",
            "email": "capyblaze@gmail.com"
        },
        "servers": ["jukebox.capyblaze.hackclub.app"],
        "securityDefinitions": {
            "userGroupAuth": {
                "type": "http",
                "scheme": "bearer"
            },
            "adminGroupAuth": {
                "type": "http",
                "scheme": "bearer"
            },
            "adminAuth": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    },
    "routes": {
        "routesDir": "src/generated",
        "authenticationModule": "src/middlewares/auth.middleware.ts"
    }
}
