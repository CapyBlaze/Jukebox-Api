{
  "name": "jukebox-api",
  "version": "1.0.0",
  "description": "A collaborative music app for creating groups and choosing songs to listen to together.",
  "main": "index.js",
  "scripts": {
    "dev": "tsoa spec-and-routes && tsx --watch src/server.ts",
    "prisma:generate": "prisma generate",
    "build": "npm run clean && npm run prisma:generate && tsoa spec-and-routes && node scripts/fix-tsoa-esm.mjs && tsc && npm run copy",
    "clean": "rimraf dist",
    "copy": "node scripts/copy-json.mjs",
    "start": "node dist/src/server.js",
    "lint": "eslint src/**/*.ts",
    "tsoa:gen": "tsoa routes && tsoa swagger",
    "test": "npm run tsoa:gen && vitest run",
    "test:watch": "npm run tsoa:gen && vitest"
  },
  "keywords": [],
  "author": "CapyBlaze <capyblaze@gmail.com>",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "prisma": "^7.8.0",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/express": "^5.0.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "picocolors": "^1.1.1",
    "swagger-ui-express": "^5.0.1",
    "systeminformation": "^5.31.7",
    "ts-node": "^10.9.2",
    "tsoa": "^7.0.0-alpha.0",
    "zod": "^4.4.3"
  }
}
